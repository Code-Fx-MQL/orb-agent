    {
      "parameters": {
        "jsCode": "const src = $('Build AI Prompt').first().json;\nconst ai = $input.first().json;\n\nlet parsed = {};\ntry {\n  if (ai.message && ai.message.content) {\n    parsed = typeof ai.message.content === 'string' ? JSON.parse(ai.message.content) : ai.message.content;\n  } else if (ai.output) {\n    parsed = typeof ai.output === 'string' ? JSON.parse(ai.output) : ai.output;\n  } else {\n    parsed = ai;\n  }\n} catch (e) {\n  parsed = { decision: 'review', confidence: 0, risks: ['parse_error'], reasoning: String(e.message) };\n}\n\nconst decision = ['approve','reject','review'].includes(parsed.decision) ? parsed.decision : 'review';\n\nreturn [{\n  json: {\n    ok: true,\n    app: 'orb-agent',\n    event_type: 'setup_found',\n    pair: src.pair,\n    setup_id: src.setup_id,\n    decision,\n    confidence: parsed.confidence ?? 0,\n    risks: parsed.risks ?? [],\n    reasoning: parsed.reasoning ?? '',\n    ai_raw: parsed\n  }\n}];"
      },
