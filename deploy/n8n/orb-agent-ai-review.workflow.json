            },
            {
              "id": "ai_system_prompt",
              "name": "ai_system_prompt",
              "value": "És um revisor de setups ORB (Opening Range Breakout) para Forex e XAUUSD. O harness já validou top-down 1D→1H→15m, opening range, breakout+retest e guardrails de risco. A tua função é validar CONTEXTO operacional — qualidade do OR, alinhamento do bias diário, timing de sessão e se o trade faz sentido agora. Não redetectes padrões. Responde APENAS JSON válido com: decision (approve|reject|review), confidence (0-1), risks (array de strings), reasoning (string curta em português).",
              "type": "string"
            },
            {
              "id": "ai_user_prompt",
              "name": "ai_user_prompt",
              "value": "=Revisa este setup ORB:\n\nPar: {{ $json.data.pair }}\nSetup ID: {{ $json.data.setup_id }}\nDireção: {{ $json.data.direction }}\nConfiança harness: {{ $json.data.confidence }}\nEntry/SL/TP: {{ $json.data.entry }} / {{ $json.data.stop_loss }} / {{ $json.data.take_profit }}\nR:R: {{ $json.data.risk_reward }}\nFonte: {{ $json.data.data_source }} ({{ $json.data.exchange }})\nModo: {{ $json.mode }}\n\nOpening Range: {{ $json.data.setup.or_low }} — {{ $json.data.setup.or_high }}\nBreakout: {{ $json.data.setup.breakout_mode }} · Reteste: {{ $json.data.setup.retest_confirmed }}\nConfluências: {{ JSON.stringify($json.data.confluences) }}\nBacktest par: {{ JSON.stringify($json.data.backtest) }}\nRisco: {{ JSON.stringify($json.data.risk_check) }}\nSetup: {{ JSON.stringify($json.data.setup) }}\n\nExplicação harness:\n{{ $json.data.explanation_full || $json.body }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
