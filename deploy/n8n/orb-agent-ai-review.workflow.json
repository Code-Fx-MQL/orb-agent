      "id": "b2000000-0000-4000-8000-000000000006",
      "name": "OpenAI Review",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [1000, 40],
      "credentials": {
        "openAiApi": {
          "id": "CONFIGURE_OPENAI_CREDENTIAL",
          "name": "OpenAI account"
        }
      }
