# Modo: analysis | paper | live (live requer gate duplo)
ORB_MODE=analysis

# Pares prioritários
ORB_PAIRS=XAUUSD,EURUSD

# Guardrails de risco
ORB_MAX_RISK_PER_TRADE=0.01
ORB_MAX_DAILY_RISK=0.03
ORB_MAX_WEEKLY_RISK=0.06
ORB_BLOCK_NEWS=true

# Live gate — NUNCA ativar sem checklist go-live
# ORB_MODE=live
# ORB_LIVE_APPROVED=true
# ORB_LIVE_APPROVAL_TOKEN=

# Dados: stub | ccxt | auto (auto = CCXT com fallback stub)
ORB_DATA_SOURCE=auto
ORB_CCXT_OHLCV_LIMIT=100
ORB_CCXT_TIMEOUT_MS=30000
# ORB_CCXT_API_KEY=
# ORB_CCXT_API_SECRET=

# Timeframes top-down (ORB: 1D -> 1H -> 15m)
ORB_DEFAULT_HTF=1d
ORB_DEFAULT_MTF=1h
ORB_DEFAULT_LTF=15m

# Opening Range: velas MTF que definem o OR (1 = primeira hora em 1H)
ORB_SESSION_CANDLES=1
ORB_BREAKOUT_MODE=retest
ORB_REQUIRE_RETEST=true

# Backtest walk-forward
ORB_BACKTEST_CANDLE_LIMIT=500
ORB_BACKTEST_HTF_LOOKBACK=30
ORB_BACKTEST_MTF_LOOKBACK=48

# Dashboard Streamlit (Fase 5)
# ORB_UI_PASSWORD=          # vazio = sem login; definir para proteger orb-ui
ORB_UI_AUTO_REFRESH_ENABLED=true
ORB_UI_AUTO_REFRESH_SECONDS=300

# Observabilidade (Fase 6)
ORB_AUDIT_DIR=data/audit
# ORB_LANGSMITH_TRACING=true
# ORB_LANGSMITH_API_KEY=
# ORB_LANGSMITH_PROJECT=orb-agent

# Webhooks (opcional — n8n/Discord)
# ORB_WEBHOOK_ENABLED=true
# ORB_WEBHOOK_URL=
# ORB_WEBHOOK_APP_ID=orb-agent
# ORB_DISCORD_WEBHOOK_URL=